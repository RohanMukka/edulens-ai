# EduLens AI — Environment Variables
# Copy this file to .env and fill in your values

# PostgreSQL connection string (e.g. from Neon, Supabase, or local Postgres)
DATABASE_URL=postgresql://user:password@host:5432/edulens

# Groq API key — get one free at https://console.groq.com
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# A long random string used to sign session cookies
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace-this-with-a-long-random-secret

# Optional: defaults to 5000
PORT=5000

# Optional: 'development' or 'production'
NODE_ENV=development
